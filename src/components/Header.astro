---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/products', label: '產品' },
  { href: '/about', label: '關於我們' },
  { href: '/contact', label: '聯繫我們' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-bg-primary/80 backdrop-blur-md border-b border-border">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group">
        <!-- Light Mode Logo -->
        <img
          src="/images/logo_white.png"
          alt="星智未來 AI Dream"
          class="h-8 md:h-10 w-auto logo-light"
        />
        <!-- Dark Mode Logo -->
        <img
          src="/images/logo_black.png"
          alt="星智未來 AI Dream"
          class="h-8 md:h-10 w-auto logo-dark hidden"
        />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-text-secondary hover:text-text-primary transition-colors font-medium"
          >
            {link.label}
          </a>
        ))}

        <!-- Theme Toggle -->
        <ThemeToggle />

        <!-- CTA Button -->
        <a
          href="/contact"
          class="px-5 py-2.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-all shadow-sm hover:shadow-md"
        >
          立即諮詢
        </a>
      </div>

      <!-- Mobile: Theme Toggle + Menu Button -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          class="p-2 text-text-primary"
          aria-label="開啟選單"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-4">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-text-secondary hover:text-text-primary transition-colors py-2 font-medium"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="px-5 py-2.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg text-center transition-all"
        >
          立即諮詢
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Light Mode: 顯示 logo_white，隱藏 logo_black */
  .logo-light {
    display: block;
  }
  .logo-dark {
    display: none;
  }

  /* Dark Mode: 顯示 logo_black，隱藏 logo_white */
  :global(.dark) .logo-light {
    display: none;
  }
  :global(.dark) .logo-dark {
    display: block;
  }
</style>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
