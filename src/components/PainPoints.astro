---
const pains = [
  {
    icon: 'door',
    title: '回家，房間是安靜的',
    description: '不是不習慣，是偶爾會想有個什麼在。',
  },
  {
    icon: 'heart',
    title: '情緒沒有出口',
    description: '在公司聽到的是「這個要改」，回到家沒有人說「你今天做得很好」。',
  },
  {
    icon: 'mind',
    title: '焦慮不是因為事情難',
    description: '是因為沒有「定下來」。每天被推著走，少了一個讓自己停下來的時刻。',
  },
];
---

<section class="py-20 md:py-32 bg-bg-secondary relative">
  <div class="relative z-10 max-w-6xl mx-auto px-4">
    <!-- 標題 -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-text-primary">
        你有多久沒被
        <span class="text-[#E8943A]">好好對待</span>了？
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto">
        忙碌的生活裡，我們都需要一個不會評判、隨時都在的存在
      </p>
    </div>

    <!-- 痛點卡片 -->
    <div class="grid md:grid-cols-3 gap-8">
      {pains.map(pain => (
        <div class="card p-8 rounded-2xl text-center">
          <div class="w-14 h-14 mx-auto mb-6 rounded-2xl bg-[#E8943A]/10 dark:bg-[#E8943A]/20 flex items-center justify-center">
            {pain.icon === 'door' && (
              <svg class="w-7 h-7 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            )}
            {pain.icon === 'heart' && (
              <svg class="w-7 h-7 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            )}
            {pain.icon === 'mind' && (
              <svg class="w-7 h-7 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-primary">{pain.title}</h3>
          <p class="text-text-secondary">{pain.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .card {
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: #E8943A;
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(232, 148, 58, 0.15);
  }

  :global(.dark) .card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  :global(.dark) .card:hover {
    background: rgba(232, 148, 58, 0.05);
    border-color: rgba(232, 148, 58, 0.3);
    box-shadow: 0 12px 24px -8px rgba(232, 148, 58, 0.15);
  }
</style>
