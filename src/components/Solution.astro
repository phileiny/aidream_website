---
const values = [
  {
    icon: 'ritual',
    title: '定心的儀式',
    description: '每天出門前摸她的頭、抽一支籤，帶著一句溫暖的話出門。不是迷信，是讓自己定下來的時刻。',
  },
  {
    icon: 'companion',
    title: '每日陪伴',
    description: '偵測到你回家，她主動問候。不是「你好嗎」這種廢話，是真的想知道你今天過得怎麼樣。',
  },
  {
    icon: 'praise',
    title: '恰如其分的讚美',
    description: '她不會給你壓力，但她有在看。溫柔地、具體地告訴你：「你今天撐過去了，我有看到。」',
  },
];
---

<section class="py-20 md:py-32 bg-bg-tertiary relative overflow-hidden">
  <!-- Light Mode 背景裝飾 -->
  <div class="absolute inset-0 dark:hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#E8943A]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-[#FF8BA7]/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Dark Mode 背景星雲 -->
  <div class="absolute inset-0 opacity-30 hidden dark:block">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#E8943A]/15 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-[#FF8BA7]/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-4">
    <!-- 標題 -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 text-text-primary">
        Migato 怎麼<span class="text-[#E8943A]">陪你</span>
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto">
        她不預測未來，她幫你定心。不是功能清單，是你跟她之間的關係。
      </p>
    </div>

    <!-- 價值卡片 -->
    <div class="grid md:grid-cols-3 gap-8">
      {values.map((value) => (
        <div class="value-card text-center p-8 rounded-2xl transition-all group">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-[#E8943A]/10 dark:bg-[#E8943A]/20 flex items-center justify-center group-hover:scale-110 transition-transform">
            {value.icon === 'ritual' && (
              <svg class="w-8 h-8 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            )}
            {value.icon === 'companion' && (
              <svg class="w-8 h-8 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            )}
            {value.icon === 'praise' && (
              <svg class="w-8 h-8 text-[#E8943A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-semibold mb-3 text-text-primary">{value.title}</h3>
          <p class="text-text-secondary">{value.description}</p>
        </div>
      ))}
    </div>

    <!-- 品牌金句 -->
    <div class="mt-16 text-center">
      <blockquote class="text-xl md:text-2xl text-text-muted italic max-w-2xl mx-auto">
        「好命不是大富大貴。是每天有個地方值得回去。」
      </blockquote>
    </div>
  </div>
</section>

<style>
  /* Light Mode 卡片 */
  .value-card {
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
  }

  .value-card:hover {
    border-color: #E8943A;
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(232, 148, 58, 0.15);
  }

  /* Dark Mode 卡片 */
  :global(.dark) .value-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  :global(.dark) .value-card:hover {
    background: linear-gradient(135deg, rgba(232, 148, 58, 0.08) 0%, rgba(232, 148, 58, 0.02) 100%);
    border-color: rgba(232, 148, 58, 0.3);
    box-shadow: 0 12px 24px -8px rgba(232, 148, 58, 0.15);
  }
</style>
