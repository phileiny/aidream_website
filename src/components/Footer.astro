---
const currentYear = new Date().getFullYear();

const links = {
  products: [
    { label: 'ContraX', href: '/products/contrax' },
    { label: 'MemoBot', href: '/products/memobot' },
  ],
  company: [
    { label: '關於我們', href: '/about' },
    { label: '聯繫我們', href: '/contact' },
    { label: '部落格', href: 'https://blog.aidream.com.tw', external: true },
  ],
};
---

<footer class="bg-bg-primary border-t border-border">
  <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="grid md:grid-cols-4 gap-8 md:gap-12">
      <!-- 品牌資訊 -->
      <div class="md:col-span-2">
        <a href="/" class="text-2xl font-bold text-text-primary hover:text-primary transition-colors">
          AI Dream
        </a>
        <p class="mt-4 text-text-secondary max-w-sm">
          用 AI 簡化工作的繁瑣，讓 AI 處理瑣事，你專注重要的事。
        </p>
      </div>

      <!-- 產品連結 -->
      <div>
        <h4 class="font-semibold mb-4 text-text-primary">產品</h4>
        <ul class="space-y-3">
          {links.products.map(link => (
            <li>
              <a href={link.href} class="text-text-secondary hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 公司連結 -->
      <div>
        <h4 class="font-semibold mb-4 text-text-primary">公司</h4>
        <ul class="space-y-3">
          {links.company.map(link => (
            <li>
              <a
                href={link.href}
                class="text-text-secondary hover:text-primary transition-colors"
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- 版權聲明 -->
    <div class="mt-12 pt-8 border-t border-border text-center text-text-muted text-sm">
      <p>&copy; {currentYear} 星智未來 AI Dream. All rights reserved.</p>
    </div>
  </div>
</footer>
