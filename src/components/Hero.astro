---

---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <!-- Light Mode 立體辦公空間背景 -->
  <div class="light-bg absolute inset-0">
    <!-- 天花板漸層 -->
    <div class="absolute inset-0 bg-gradient-to-b from-blue-50 via-white to-transparent" style="height: 40%;"></div>

    <!-- 3D 透視辦公空間 -->
    <div class="office-3d absolute inset-0" style="perspective: 1200px;">
      <!-- 地板 -->
      <div class="floor"></div>

      <!-- 左側辦公區 - 有人坐著工作 -->
      <div class="office-left">
        <svg viewBox="0 0 300 350" class="office-scene-left">
          <!-- 辦公桌 - 立體 -->
          <g class="desk-3d">
            <!-- 桌面 -->
            <path d="M 30 180 L 50 165 L 250 165 L 270 180 L 270 188 L 250 173 L 50 173 L 30 188 Z" fill="#A08060"/>
            <rect x="50" y="165" width="200" height="8" fill="#8B7355"/>
            <!-- 桌腳 -->
            <rect x="55" y="173" width="8" height="80" fill="#6B5344"/>
            <rect x="237" y="173" width="8" height="80" fill="#5C4D3A"/>
            <!-- 桌面陰影 -->
            <rect x="50" y="165" width="200" height="8" fill="rgba(0,0,0,0.1)"/>
          </g>

          <!-- 電腦螢幕 - 立體 -->
          <g class="monitor-3d">
            <rect x="110" y="95" width="80" height="60" rx="3" fill="#2D2D2D"/>
            <rect x="114" y="99" width="72" height="48" rx="2" fill="#1E40AF"/>
            <!-- 螢幕內容 - 程式碼 -->
            <line x1="120" y1="108" x2="160" y2="108" stroke="#60A5FA" stroke-width="2"/>
            <line x1="120" y1="116" x2="175" y2="116" stroke="#34D399" stroke-width="2"/>
            <line x1="125" y1="124" x2="165" y2="124" stroke="#F472B6" stroke-width="2"/>
            <line x1="125" y1="132" x2="155" y2="132" stroke="#FBBF24" stroke-width="2"/>
            <!-- 螢幕支架 -->
            <rect x="145" y="155" width="10" height="12" fill="#374151"/>
            <ellipse cx="150" cy="165" rx="20" ry="5" fill="#374151"/>
          </g>

          <!-- 鍵盤 -->
          <rect x="120" y="155" width="60" height="8" rx="2" fill="#1F2937"/>
          <rect x="122" y="156" width="56" height="6" rx="1" fill="#374151"/>

          <!-- 滑鼠 -->
          <ellipse cx="195" cy="158" rx="8" ry="5" fill="#1F2937"/>

          <!-- 咖啡杯 -->
          <g class="coffee-cup">
            <rect x="80" y="150" width="15" height="18" rx="2" fill="#F5F5F5"/>
            <ellipse cx="87" cy="150" rx="7" ry="3" fill="#E5E5E5"/>
            <path d="M 95 155 Q 102 158 95 163" stroke="#D4D4D4" stroke-width="2" fill="none"/>
            <!-- 熱氣 -->
            <path class="steam" d="M 85 145 Q 83 140 86 135" stroke="#94A3B8" stroke-width="1" fill="none" opacity="0.6"/>
            <path class="steam steam-2" d="M 89 145 Q 91 140 88 135" stroke="#94A3B8" stroke-width="1" fill="none" opacity="0.6"/>
          </g>

          <!-- 坐著的人 -->
          <g class="person-working">
            <!-- 椅子 -->
            <rect x="130" y="220" width="50" height="8" rx="3" fill="#374151"/>
            <rect x="125" y="195" width="60" height="30" rx="5" fill="#1F2937"/>
            <rect x="150" y="228" width="10" height="25" fill="#4B5563"/>
            <ellipse cx="155" cy="253" rx="25" ry="6" fill="#374151"/>

            <!-- 身體 -->
            <ellipse cx="155" cy="175" rx="25" ry="20" fill="#3B82F6"/>
            <!-- 頭 -->
            <circle cx="155" cy="140" r="18" fill="#FBBF24"/>
            <!-- 頭髮 -->
            <ellipse cx="155" cy="128" rx="16" ry="10" fill="#1F2937"/>
            <!-- 眼鏡 -->
            <rect x="145" y="138" width="8" height="6" rx="1" fill="none" stroke="#374151" stroke-width="1.5"/>
            <rect x="157" y="138" width="8" height="6" rx="1" fill="none" stroke="#374151" stroke-width="1.5"/>
            <line x1="153" y1="141" x2="157" y2="141" stroke="#374151" stroke-width="1"/>

            <!-- 手臂 - 打字動作 -->
            <g class="typing-arms">
              <!-- 左手 -->
              <path d="M 130 175 Q 115 185 125 195" stroke="#FBBF24" stroke-width="8" fill="none" stroke-linecap="round"/>
              <circle cx="125" cy="195" r="5" fill="#FBBF24"/>
              <!-- 右手 -->
              <path d="M 180 175 Q 195 185 185 195" stroke="#FBBF24" stroke-width="8" fill="none" stroke-linecap="round"/>
              <circle cx="185" cy="195" r="5" fill="#FBBF24"/>
            </g>
          </g>
        </svg>
      </div>

      <!-- 右側休息區 - 兩人喝咖啡閒聊 -->
      <div class="office-right">
        <svg viewBox="0 0 320 350" class="office-scene-right">
          <!-- 高腳桌 -->
          <g class="high-table">
            <ellipse cx="160" cy="200" rx="50" ry="15" fill="#8B7355"/>
            <ellipse cx="160" cy="195" rx="50" ry="15" fill="#A08060"/>
            <rect x="155" y="200" width="10" height="80" fill="#6B5344"/>
            <ellipse cx="160" cy="280" rx="30" ry="8" fill="#5C4D3A"/>
          </g>

          <!-- 桌上咖啡杯 -->
          <g class="table-items">
            <rect x="140" y="180" width="12" height="15" rx="2" fill="#F5F5F5"/>
            <ellipse cx="146" cy="180" rx="6" ry="2" fill="#8B4513"/>
            <rect x="168" y="182" width="12" height="13" rx="2" fill="#FEF3C7"/>
            <ellipse cx="174" cy="182" rx="6" ry="2" fill="#92400E"/>
          </g>

          <!-- 左邊的人 - 拿著咖啡 -->
          <g class="person-left-chat">
            <!-- 身體 -->
            <ellipse cx="90" cy="190" rx="22" ry="35" fill="#EC4899"/>
            <!-- 頭 -->
            <circle cx="90" cy="130" r="20" fill="#FCD34D"/>
            <!-- 長髮 -->
            <ellipse cx="90" cy="135" rx="22" ry="25" fill="#7C3AED"/>
            <ellipse cx="90" cy="125" rx="18" ry="12" fill="#FCD34D"/>
            <!-- 表情 - 微笑 -->
            <circle cx="83" cy="128" r="2" fill="#1F2937"/>
            <circle cx="97" cy="128" r="2" fill="#1F2937"/>
            <path d="M 83 136 Q 90 142 97 136" stroke="#1F2937" stroke-width="2" fill="none"/>

            <!-- 手拿咖啡 -->
            <g class="holding-coffee">
              <path d="M 112 180 Q 125 175 130 190" stroke="#FCD34D" stroke-width="7" fill="none" stroke-linecap="round"/>
              <rect x="125" y="185" width="14" height="18" rx="2" fill="#F5F5F5"/>
              <ellipse cx="132" cy="185" rx="7" ry="3" fill="#8B4513"/>
            </g>

            <!-- 腿 -->
            <rect x="78" y="220" width="10" height="50" rx="3" fill="#1F2937"/>
            <rect x="92" y="220" width="10" height="50" rx="3" fill="#1F2937"/>
            <ellipse cx="83" cy="270" rx="12" ry="5" fill="#374151"/>
            <ellipse cx="97" cy="270" rx="12" ry="5" fill="#374151"/>
          </g>

          <!-- 右邊的人 - 說話中 -->
          <g class="person-right-chat">
            <!-- 身體 -->
            <ellipse cx="230" cy="195" rx="24" ry="38" fill="#10B981"/>
            <!-- 頭 -->
            <circle cx="230" cy="130" r="20" fill="#FBBF24"/>
            <!-- 短髮 -->
            <ellipse cx="230" cy="120" rx="18" ry="12" fill="#1F2937"/>
            <!-- 表情 - 說話 -->
            <circle cx="223" cy="128" r="2" fill="#1F2937"/>
            <circle cx="237" cy="128" r="2" fill="#1F2937"/>
            <ellipse cx="230" cy="140" rx="5" ry="3" fill="#1F2937"/>

            <!-- 說話泡泡 -->
            <g class="speech-bubble">
              <ellipse cx="270" cy="100" rx="25" ry="15" fill="white" stroke="#E5E7EB" stroke-width="2"/>
              <path d="M 255 112 L 248 125 L 260 115" fill="white"/>
              <text x="270" y="104" text-anchor="middle" fill="#6B7280" font-size="10">哈哈</text>
            </g>

            <!-- 手勢 - 比劃 -->
            <g class="gesture-hand">
              <path d="M 206 185 Q 185 175 180 190" stroke="#FBBF24" stroke-width="7" fill="none" stroke-linecap="round"/>
              <circle cx="180" cy="190" r="6" fill="#FBBF24"/>
            </g>

            <!-- 腿 -->
            <rect x="218" y="228" width="10" height="45" rx="3" fill="#374151"/>
            <rect x="232" y="228" width="10" height="45" rx="3" fill="#374151"/>
            <ellipse cx="223" cy="273" rx="12" ry="5" fill="#1F2937"/>
            <ellipse cx="237" cy="273" rx="12" ry="5" fill="#1F2937"/>
          </g>
        </svg>
      </div>

      <!-- 後方牆面元素 -->
      <div class="back-wall">
        <!-- 左側 - 投影 PPT -->
        <svg viewBox="0 0 160 120" class="projector-screen">
          <!-- 投影幕框 -->
          <rect x="0" y="0" width="160" height="120" fill="#1E293B" rx="2"/>
          <rect x="4" y="4" width="152" height="112" fill="#0F172A" rx="1"/>

          <!-- PPT 內容 -->
          <!-- 標題 -->
          <text x="80" y="22" text-anchor="middle" fill="#60A5FA" font-size="10" font-weight="bold">Q4 業績報告</text>

          <!-- 圖表 - 長條圖 -->
          <rect x="20" y="35" width="12" height="30" fill="#3B82F6" rx="1"/>
          <rect x="38" y="45" width="12" height="20" fill="#3B82F6" rx="1"/>
          <rect x="56" y="28" width="12" height="37" fill="#10B981" rx="1"/>
          <rect x="74" y="38" width="12" height="27" fill="#10B981" rx="1"/>

          <!-- 圓餅圖 -->
          <circle cx="120" cy="50" r="18" fill="#3B82F6"/>
          <path d="M 120 50 L 120 32 A 18 18 0 0 1 135 58 Z" fill="#F59E0B"/>
          <path d="M 120 50 L 135 58 A 18 18 0 0 1 108 65 Z" fill="#10B981"/>

          <!-- 重點項目 -->
          <circle cx="18" cy="82" r="3" fill="#F59E0B"/>
          <line x1="25" y1="82" x2="75" y2="82" stroke="#94A3B8" stroke-width="2"/>
          <circle cx="18" cy="94" r="3" fill="#10B981"/>
          <line x1="25" y1="94" x2="65" y2="94" stroke="#94A3B8" stroke-width="2"/>
          <circle cx="18" cy="106" r="3" fill="#3B82F6"/>
          <line x1="25" y1="106" x2="55" y2="106" stroke="#94A3B8" stroke-width="2"/>

          <!-- 頁碼 -->
          <text x="145" y="110" fill="#64748B" font-size="6">3/12</text>
        </svg>

        <!-- 右側 - 白板潦草字 -->
        <svg viewBox="0 0 140 100" class="whiteboard-messy">
          <!-- 白板框 -->
          <rect x="0" y="0" width="140" height="100" fill="#F8FAFC" stroke="#CBD5E1" stroke-width="3" rx="2"/>

          <!-- 潦草手寫字 - 使用 path 模擬 -->
          <!-- "Ideas" -->
          <path d="M 15 20 Q 17 15 20 20 M 22 15 L 22 22 M 26 15 Q 32 14 30 18 Q 28 22 32 22 M 36 22 Q 34 18 38 15 Q 42 18 40 22 M 44 18 Q 48 14 50 20"
                stroke="#E11D48" stroke-width="1.5" fill="none" stroke-linecap="round"/>

          <!-- 箭頭和連線 -->
          <path d="M 20 30 L 40 35 L 35 50 M 38 47 L 35 50 L 38 52" stroke="#3B82F6" stroke-width="1.5" fill="none"/>
          <path d="M 60 28 L 90 32 M 87 29 L 90 32 L 87 35" stroke="#3B82F6" stroke-width="1.5" fill="none"/>

          <!-- 圓圈框重點 -->
          <ellipse cx="75" cy="50" rx="25" ry="12" fill="none" stroke="#F59E0B" stroke-width="1.5"/>
          <text x="75" y="53" text-anchor="middle" fill="#1E293B" font-size="7" font-family="Comic Sans MS, cursive">重要!</text>

          <!-- 潦草筆記 -->
          <path d="M 15 60 Q 20 58 30 60 Q 40 62 50 60" stroke="#64748B" stroke-width="1" fill="none"/>
          <path d="M 15 68 Q 25 66 40 68" stroke="#64748B" stroke-width="1" fill="none"/>
          <path d="M 15 76 Q 22 74 35 76 Q 45 78 55 76" stroke="#64748B" stroke-width="1" fill="none"/>

          <!-- 打勾 -->
          <path d="M 100 40 L 105 48 L 118 32" stroke="#10B981" stroke-width="2.5" fill="none" stroke-linecap="round"/>

          <!-- 星星標記 -->
          <path d="M 110 65 L 112 70 L 118 70 L 113 74 L 115 80 L 110 76 L 105 80 L 107 74 L 102 70 L 108 70 Z" fill="#FBBF24"/>

          <!-- TODO -->
          <text x="95" y="92" fill="#6366F1" font-size="8" font-family="Comic Sans MS, cursive">TODO</text>
          <path d="M 85 88 L 85 95 L 125 95 L 125 88" stroke="#6366F1" stroke-width="1" fill="none"/>
        </svg>
      </div>
    </div>

    <!-- 環境光效果 -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-100/30 rounded-full blur-3xl"></div>
    <div class="absolute top-20 right-1/4 w-64 h-64 bg-orange-100/20 rounded-full blur-3xl"></div>
  </div>

  <!-- Light Mode 機器人 -->
  <div class="robot-container light-robot">
    <div class="robot-shadow"></div>
    <svg viewBox="0 0 200 280" class="johnny5-robot">
      <!-- 天線 -->
      <line x1="70" y1="30" x2="70" y2="0" stroke="#555" stroke-width="3"/>
      <circle cx="70" cy="0" r="5" fill="#FF4444"/>
      <line x1="130" y1="30" x2="130" y2="0" stroke="#555" stroke-width="3"/>
      <circle cx="130" cy="0" r="5" fill="#FF4444"/>

      <!-- 頭部基座 -->
      <rect x="50" y="25" width="100" height="45" fill="#3D3D3D" rx="4"/>
      <rect x="55" y="30" width="90" height="35" fill="#4A4A4A" rx="3"/>

      <!-- 眼睛（大燈） -->
      <circle cx="75" cy="48" r="14" fill="#2A2A2A"/>
      <circle cx="75" cy="48" r="11" fill="#FFFDE7" class="eye-glow"/>
      <circle cx="75" cy="48" r="7" fill="#FFE500"/>
      <circle cx="72" cy="45" r="2" fill="#FFF"/>

      <circle cx="125" cy="48" r="14" fill="#2A2A2A"/>
      <circle cx="125" cy="48" r="11" fill="#FFFDE7" class="eye-glow"/>
      <circle cx="125" cy="48" r="7" fill="#FFE500"/>
      <circle cx="122" cy="45" r="2" fill="#FFF"/>

      <!-- 頭部顯示器 -->
      <rect x="88" y="32" width="24" height="10" fill="#1A1A1A" rx="2"/>
      <rect x="90" y="34" width="20" height="6" fill="#00FF88" class="display-blink" rx="1"/>

      <!-- 脖子 -->
      <rect x="88" y="70" width="24" height="20" fill="#555"/>
      <rect x="92" y="72" width="16" height="16" fill="#444"/>

      <!-- 身體 V 字型 -->
      <path d="M 35 90 L 100 175 L 165 90 L 145 90 L 100 150 L 55 90 Z" fill="#F8F8F8" stroke="#3B82F6" stroke-width="2"/>
      <path d="M 50 92 L 100 155 L 150 92" fill="none" stroke="#E5E5E5" stroke-width="1"/>

      <!-- 身體中央顯示器 -->
      <rect x="78" y="100" width="44" height="28" fill="#1A1A1A" rx="4"/>
      <rect x="82" y="104" width="36" height="20" fill="#0D1117" rx="2"/>
      <text x="100" y="118" text-anchor="middle" fill="#00D4FF" font-size="11" font-family="monospace" font-weight="bold">AI</text>

      <!-- 藍色裝飾條 -->
      <rect x="48" y="95" width="6" height="45" fill="#3B82F6" rx="2"/>
      <rect x="146" y="95" width="6" height="45" fill="#3B82F6" rx="2"/>

      <!-- 手臂 -->
      <g class="arm-left">
        <rect x="12" y="95" width="28" height="12" fill="#555" rx="4"/>
        <rect x="2" y="100" width="18" height="35" fill="#444" rx="3"/>
        <rect x="5" y="130" width="12" height="15" fill="#333" rx="2"/>
      </g>
      <g class="arm-right">
        <rect x="160" y="95" width="28" height="12" fill="#555" rx="4"/>
        <rect x="180" y="100" width="18" height="35" fill="#444" rx="3"/>
        <rect x="183" y="130" width="12" height="15" fill="#333" rx="2"/>
      </g>

      <!-- 下半身基座 -->
      <path d="M 55 170 L 145 170 L 155 195 L 45 195 Z" fill="#4A4A4A"/>

      <!-- 履帶 -->
      <g class="track-left">
        <rect x="30" y="190" width="55" height="85" fill="#2A2A2A" rx="22"/>
        <rect x="36" y="196" width="43" height="73" fill="#1A1A1A" rx="18"/>
        <circle cx="57" cy="215" r="14" fill="#333" stroke="#444" stroke-width="2"/>
        <circle cx="57" cy="215" r="6" fill="#222"/>
        <circle cx="57" cy="258" r="14" fill="#333" stroke="#444" stroke-width="2"/>
        <circle cx="57" cy="258" r="6" fill="#222"/>
      </g>
      <g class="track-right">
        <rect x="115" y="190" width="55" height="85" fill="#2A2A2A" rx="22"/>
        <rect x="121" y="196" width="43" height="73" fill="#1A1A1A" rx="18"/>
        <circle cx="143" cy="215" r="14" fill="#333" stroke="#444" stroke-width="2"/>
        <circle cx="143" cy="215" r="6" fill="#222"/>
        <circle cx="143" cy="258" r="14" fill="#333" stroke="#444" stroke-width="2"/>
        <circle cx="143" cy="258" r="6" fill="#222"/>
      </g>
    </svg>
  </div>

  <!-- Dark Mode 星空 -->
  <div class="dark-bg absolute inset-0"></div>
  <div class="dark-stars stars-1"></div>
  <div class="dark-stars stars-2"></div>
  <div class="dark-stars stars-3"></div>
  <div class="dark-polaris"></div>
  <div class="dark-dipper">
    <div class="dipper-star" style="--x: 0; --y: 0;"></div>
    <div class="dipper-star" style="--x: 30px; --y: 15px;"></div>
    <div class="dipper-star" style="--x: 60px; --y: 10px;"></div>
    <div class="dipper-star" style="--x: 90px; --y: 25px;"></div>
    <div class="dipper-star" style="--x: 115px; --y: 55px;"></div>
    <div class="dipper-star" style="--x: 145px; --y: 75px;"></div>
    <div class="dipper-star" style="--x: 175px; --y: 60px;"></div>
    <svg class="dipper-lines" viewBox="0 0 200 100">
      <polyline points="5,5 35,20 65,15 95,30 120,60 150,80 180,65" fill="none" stroke="rgba(165, 196, 255, 0.3)" stroke-width="1"/>
    </svg>
  </div>
  <div class="dark-nebula absolute inset-0"></div>
  <div class="dark-planet planet-1"></div>
  <div class="dark-planet planet-2"></div>

  <!-- 內容 -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm text-[#E8943A] text-sm font-medium mb-8 shadow-sm">
      <span class="w-2 h-2 rounded-full bg-[#E8943A] animate-pulse"></span>
      全新產品 Migato 即將登場
    </div>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-text-primary drop-shadow-sm">
      帶牠回家，
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#E8943A] to-[#FF8BA7]">好運進門</span>
    </h1>

    <p class="text-xl md:text-2xl text-text-secondary mb-4">
      桌上的貓，聽得懂你說的話
    </p>

    <p class="text-text-muted mb-10 max-w-2xl mx-auto">
      Migato 是一隻會說話的三花貓，記得你說過的話，陪你度過每一天。<br class="hidden md:block" />
      每日陪伴，好命自來。
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/products/migato" class="px-8 py-3.5 bg-[#E8943A] hover:bg-[#d4832e] text-white font-semibold rounded-lg transition-all shadow-lg shadow-[#E8943A]/25 hover:shadow-xl hover:shadow-[#E8943A]/30 hover:-translate-y-0.5">
        認識 Migato
      </a>
      <a href="/products" class="px-8 py-3.5 bg-white/80 backdrop-blur-sm border border-gray-200 hover:border-[#E8943A] text-text-primary font-semibold rounded-lg transition-all hover:bg-white">
        探索所有產品
      </a>
    </div>
  </div>

  <!-- 向下滾動提示 -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  /* ===== Light Mode 3D 辦公空間 ===== */
  .light-bg, .light-robot {
    display: block;
  }

  .office-3d {
    transform-style: preserve-3d;
  }

  /* 地板 */
  .floor {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background:
      linear-gradient(to bottom, rgba(226, 232, 240, 0) 0%, rgba(226, 232, 240, 0.8) 100%),
      repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(148, 163, 184, 0.15) 80px, rgba(148, 163, 184, 0.15) 82px),
      repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(148, 163, 184, 0.15) 80px, rgba(148, 163, 184, 0.15) 82px);
    background-color: #F1F5F9;
    transform: rotateX(60deg);
    transform-origin: bottom center;
  }

  /* 左側辦公區 */
  .office-left {
    position: absolute;
    left: 2%;
    bottom: 8%;
    transform: perspective(800px) rotateY(12deg);
    transform-origin: left center;
  }

  .office-scene-left {
    width: 220px;
    height: 260px;
    filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.1));
  }

  /* 右側休息區 */
  .office-right {
    position: absolute;
    right: 2%;
    bottom: 8%;
